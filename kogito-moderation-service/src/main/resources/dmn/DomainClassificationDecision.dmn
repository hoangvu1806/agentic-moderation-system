  <inputData id="input-llm-domain-hint" name="llm_domain_hint">
    <variable id="variable-llm-domain-hint" name="llm_domain_hint" typeRef="string" />
  </inputData>
  <inputData id="input-llm-domain-confidence-hint" name="llm_domain_confidence_hint">
    <variable id="variable-llm-domain-confidence-hint" name="llm_domain_confidence_hint" typeRef="number" />
  </inputData>
  <inputData id="input-declared-category" name="declared_category">
    <variable id="variable-declared-category" name="declared_category" typeRef="string" />
  </inputData>
  <inputData id="input-source-channel" name="source_channel">
    <variable id="variable-source-channel" name="source_channel" typeRef="string" />
  </inputData>
  <inputData id="input-has-image" name="has_image">
    <variable id="variable-has-image" name="has_image" typeRef="boolean" />
  </inputData>
  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="diagram-domain-classification" name="Domain Classification Decision">
      <di:extension>
        <kie:ComponentsWidthsExtension>
          <kie:ComponentWidths dmnElementRef="decision-table-domain-classification">
            <kie:width>100</kie:width>
            <kie:width>557</kie:width>
          </kie:ComponentWidths>
        </kie:ComponentsWidthsExtension>
      </di:extension>
      <dmndi:DMNShape id="shape-llm-domain-hint" dmnElementRef="input-llm-domain-hint">
        <dc:Bounds x="80" y="60" width="190" height="70" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="shape-llm-domain-confidence-hint" dmnElementRef="input-llm-domain-confidence-hint">
        <dc:Bounds x="80" y="150" width="240" height="70" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="shape-declared-category" dmnElementRef="input-declared-category">
        <dc:Bounds x="80" y="240" width="190" height="70" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="shape-source-channel" dmnElementRef="input-source-channel">
        <dc:Bounds x="80" y="330" width="190" height="70" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="shape-has-image" dmnElementRef="input-has-image">
        <dc:Bounds x="80" y="420" width="190" height="70" />
      </dmndi:DMNShape>
      <dmndi:DMNShape id="shape-domain-classification" dmnElementRef="decision-domain-classification">
        <dc:Bounds x="470" y="250" width="260" height="100" />
      </dmndi:DMNShape>
      <dmndi:DMNEdge id="edge-llm-domain-hint" dmnElementRef="requirement-llm-domain-hint">
        <di:waypoint x="270" y="95" />
        <di:waypoint x="470" y="300" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="edge-llm-domain-confidence-hint" dmnElementRef="requirement-llm-domain-confidence-hint">
        <di:waypoint x="320" y="185" />
        <di:waypoint x="470" y="300" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="edge-declared-category" dmnElementRef="requirement-declared-category">
        <di:waypoint x="270" y="275" />
        <di:waypoint x="470" y="300" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="edge-source-channel" dmnElementRef="requirement-source-channel">
        <di:waypoint x="270" y="365" />
        <di:waypoint x="470" y="300" />
      </dmndi:DMNEdge>
      <dmndi:DMNEdge id="edge-has-image" dmnElementRef="requirement-has-image">
        <di:waypoint x="270" y="455" />
        <di:waypoint x="470" y="300" />
      </dmndi:DMNEdge>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>
</definitions>
