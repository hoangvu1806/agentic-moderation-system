        <inputEntry id="domain-r3-confidence-input">
          <text>&gt;= 0.70</text>
        </inputEntry>
        <inputEntry id="domain-r3-category">
          <text>-</text>
        </inputEntry>
        <inputEntry id="domain-r3-source-channel">
          <text>-</text>
        </inputEntry>
        <outputEntry id="domain-r3-domain">
          <text>&quot;REAL_ESTATE&quot;</text>
