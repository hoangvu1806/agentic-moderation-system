        </outputEntry>
        <outputEntry id="domain-r5-image-profile">
          <text>&quot;enterprise_hr_image_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r5-review">
          <text>false</text>
        </outputEntry>
      </rule>
      <rule id="rule-edtech-category">
        <inputEntry id="domain-r6-domain-hint">
          <text>-</text>
        </inputEntry>
        <inputEntry id="domain-r6-confidence-input">
          <text>&lt; 0.70</text>
        </inputEntry>
        <inputEntry id="domain-r6-category">
          <text>&quot;education&quot;, &quot;course&quot;, &quot;learning&quot;, &quot;exam&quot;</text>
        </inputEntry>
        <inputEntry id="domain-r6-source-channel">
          <text>-</text>
        </inputEntry>
        <outputEntry id="domain-r6-domain">
          <text>&quot;EDTECH&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r6-confidence">
          <text>0.75</text>
        </outputEntry>
        <outputEntry id="domain-r6-analysis">
          <text>&quot;EDTECH_ELEARNING&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r6-content-profile">
          <text>&quot;edtech_text_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r6-image-profile">
          <text>&quot;edtech_image_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r6-review">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="rule-ecommerce-category">
        <inputEntry id="domain-r7-domain-hint">
          <text>-</text>
        </inputEntry>
        <inputEntry id="domain-r7-confidence-input">
          <text>&lt; 0.70</text>
        </inputEntry>
        <inputEntry id="domain-r7-category">
          <text>&quot;marketplace&quot;, &quot;product&quot;, &quot;shopping&quot;</text>
        </inputEntry>
        <inputEntry id="domain-r7-source-channel">
          <text>-</text>
        </inputEntry>
        <outputEntry id="domain-r7-domain">
          <text>&quot;ECOMMERCE&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r7-confidence">
          <text>0.75</text>
        </outputEntry>
        <outputEntry id="domain-r7-analysis">
          <text>&quot;ECOMMERCE_MARKETPLACE&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r7-content-profile">
          <text>&quot;ecommerce_text_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r7-image-profile">
          <text>&quot;ecommerce_image_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r7-review">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="rule-real-estate-category">
        <inputEntry id="domain-r8-domain-hint">
          <text>-</text>
        </inputEntry>
        <inputEntry id="domain-r8-confidence-input">
          <text>&lt; 0.70</text>
        </inputEntry>
        <inputEntry id="domain-r8-category">
          <text>&quot;real_estate&quot;, &quot;property&quot;, &quot;listing&quot;, &quot;housing&quot;</text>
        </inputEntry>
        <inputEntry id="domain-r8-source-channel">
          <text>-</text>
        </inputEntry>
        <outputEntry id="domain-r8-domain">
          <text>&quot;REAL_ESTATE&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r8-confidence">
          <text>0.75</text>
        </outputEntry>
        <outputEntry id="domain-r8-analysis">
          <text>&quot;REAL_ESTATE_LISTING&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r8-content-profile">
