        <outputEntry id="domain-r3-confidence">
          <text>0.95</text>
        </outputEntry>
        <outputEntry id="domain-r3-analysis">
          <text>&quot;REAL_ESTATE_LISTING&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r3-content-profile">
          <text>&quot;real_estate_text_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r3-image-profile">
          <text>&quot;real_estate_image_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r3-review">
          <text>false</text>
        </outputEntry>
      </rule>
      <rule id="rule-healthcare-high">
        <inputEntry id="domain-r4-domain-hint">
          <text>&quot;HEALTHCARE&quot;</text>
        </inputEntry>
        <inputEntry id="domain-r4-confidence-input">
          <text>&gt;= 0.70</text>
        </inputEntry>
        <inputEntry id="domain-r4-category">
          <text>-</text>
        </inputEntry>
        <inputEntry id="domain-r4-source-channel">
          <text>-</text>
