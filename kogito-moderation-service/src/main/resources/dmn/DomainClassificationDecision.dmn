      <rule id="rule-enterprise-hr-high">
        <inputEntry id="domain-r5-domain-hint">
          <text>&quot;ENTERPRISE_HR&quot;</text>
        </inputEntry>
        <inputEntry id="domain-r5-confidence-input">
          <text>&gt;= 0.70</text>
        </inputEntry>
        <inputEntry id="domain-r5-category">
          <text>-</text>
        </inputEntry>
        <inputEntry id="domain-r5-source-channel">
          <text>-</text>
        </inputEntry>
        <outputEntry id="domain-r5-domain">
          <text>&quot;ENTERPRISE_HR&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r5-confidence">
          <text>0.95</text>
        </outputEntry>
        <outputEntry id="domain-r5-analysis">
