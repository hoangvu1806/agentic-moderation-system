        </outputEntry>
        <outputEntry id="domain-r8-image-profile">
          <text>&quot;real_estate_image_moderation_v1&quot;</text>
        </outputEntry>
        <outputEntry id="domain-r8-review">
          <text>true</text>
        </outputEntry>
      </rule>
      <rule id="rule-healthcare-category">
        <inputEntry id="domain-r9-domain-hint">
          <text>-</text>
        </inputEntry>
        <inputEntry id="domain-r9-confidence-input">
          <text>&lt; 0.70</text>
        </inputEntry>
        <inputEntry id="domain-r9-category">
          <text>&quot;healthcare&quot;, &quot;medical&quot;, &quot;telemedicine&quot;, &quot;wellness&quot;</text>
        </inputEntry>
        <inputEntry id="domain-r9-source-channel">
