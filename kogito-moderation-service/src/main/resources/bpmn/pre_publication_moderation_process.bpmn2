    <bpmn2:sequenceFlow id="Flow_Start_To_SetPending" sourceRef="StartEvent_ContentSubmitted" targetRef="Task_SetPendingModeration" />
    <bpmn2:sequenceFlow id="Flow_SetPending_To_DomainConfidence" sourceRef="Task_SetPendingModeration" targetRef="Gateway_DomainConfidence" />
    <bpmn2:sequenceFlow id="Flow_DomainConfidence_To_ManualReview" name="low confidence or review required" sourceRef="Gateway_DomainConfidence" targetRef="Gateway_ManualReviewJoin">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return domain_confidence == null || domain_confidence &lt; 0.60 || requires_domain_review == true;</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DomainConfidence_To_DomainRouting" name="domain accepted" sourceRef="Gateway_DomainConfidence" targetRef="Gateway_DomainRouting" />
    <bpmn2:sequenceFlow id="Flow_DomainRouting_To_EdTechName" name="EDTECH" sourceRef="Gateway_DomainRouting" targetRef="Task_SetEdTechDmnName">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;EDTECH&quot;.equals(detected_domain);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DomainRouting_To_EcommerceName" name="ECOMMERCE" sourceRef="Gateway_DomainRouting" targetRef="Task_SetEcommerceDmnName">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;ECOMMERCE&quot;.equals(detected_domain);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DomainRouting_To_RealEstateName" name="REAL_ESTATE" sourceRef="Gateway_DomainRouting" targetRef="Task_SetRealEstateDmnName">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;REAL_ESTATE&quot;.equals(detected_domain);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DomainRouting_To_HealthcareName" name="HEALTHCARE" sourceRef="Gateway_DomainRouting" targetRef="Task_SetHealthcareDmnName">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;HEALTHCARE&quot;.equals(detected_domain);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DomainRouting_To_EnterpriseHrName" name="ENTERPRISE_HR" sourceRef="Gateway_DomainRouting" targetRef="Task_SetEnterpriseHrDmnName">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;ENTERPRISE_HR&quot;.equals(detected_domain);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DomainRouting_To_ManualReview" name="unknown domain" sourceRef="Gateway_DomainRouting" targetRef="Gateway_ManualReviewJoin" />
    <bpmn2:sequenceFlow id="Flow_EdTechName_To_InvokeEdTech" sourceRef="Task_SetEdTechDmnName" targetRef="Task_InvokeEdTechDmn" />
    <bpmn2:sequenceFlow id="Flow_EcommerceName_To_InvokeEcommerce" sourceRef="Task_SetEcommerceDmnName" targetRef="Task_InvokeEcommerceDmn" />
    <bpmn2:sequenceFlow id="Flow_RealEstateName_To_InvokeRealEstate" sourceRef="Task_SetRealEstateDmnName" targetRef="Task_InvokeRealEstateDmn" />
    <bpmn2:sequenceFlow id="Flow_HealthcareName_To_InvokeHealthcare" sourceRef="Task_SetHealthcareDmnName" targetRef="Task_InvokeHealthcareDmn" />
    <bpmn2:sequenceFlow id="Flow_EnterpriseHrName_To_InvokeEnterpriseHr" sourceRef="Task_SetEnterpriseHrDmnName" targetRef="Task_InvokeEnterpriseHrDmn" />
    <bpmn2:sequenceFlow id="Flow_InvokeEdTech_To_DmnJoin" sourceRef="Task_InvokeEdTechDmn" targetRef="Gateway_DmnJoin" />
    <bpmn2:sequenceFlow id="Flow_InvokeEcommerce_To_DmnJoin" sourceRef="Task_InvokeEcommerceDmn" targetRef="Gateway_DmnJoin" />
    <bpmn2:sequenceFlow id="Flow_InvokeRealEstate_To_DmnJoin" sourceRef="Task_InvokeRealEstateDmn" targetRef="Gateway_DmnJoin" />
    <bpmn2:sequenceFlow id="Flow_InvokeHealthcare_To_DmnJoin" sourceRef="Task_InvokeHealthcareDmn" targetRef="Gateway_DmnJoin" />
    <bpmn2:sequenceFlow id="Flow_InvokeEnterpriseHr_To_DmnJoin" sourceRef="Task_InvokeEnterpriseHrDmn" targetRef="Gateway_DmnJoin" />
    <bpmn2:sequenceFlow id="Flow_DmnJoin_To_DecisionGateway" sourceRef="Gateway_DmnJoin" targetRef="Gateway_ModerationDecision" />
    <bpmn2:sequenceFlow id="Flow_DecisionGateway_To_Published" name="ALLOW" sourceRef="Gateway_ModerationDecision" targetRef="Task_SetPublished">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;ALLOW&quot;.equals(dmn_decision);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DecisionGateway_To_PublishedWithWarning" name="WARN_ALLOW" sourceRef="Gateway_ModerationDecision" targetRef="Task_SetPublishedWithWarning">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;WARN_ALLOW&quot;.equals(dmn_decision);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DecisionGateway_To_Rejected" name="REJECT" sourceRef="Gateway_ModerationDecision" targetRef="Task_SetRejected">
      <bpmn2:conditionExpression xsi:type="bpmn2:tFormalExpression" language="http://www.java.com/java">return &quot;REJECT&quot;.equals(dmn_decision) || &quot;TEMP_BAN&quot;.equals(dmn_decision);</bpmn2:conditionExpression>
    </bpmn2:sequenceFlow>
    <bpmn2:sequenceFlow id="Flow_DecisionGateway_To_ManualReview" name="MANUAL_REVIEW / default" sourceRef="Gateway_ModerationDecision" targetRef="Gateway_ManualReviewJoin" />
    <bpmn2:sequenceFlow id="Flow_ManualReviewJoin_To_SetManualReview" sourceRef="Gateway_ManualReviewJoin" targetRef="Task_SetManualReview" />
    <bpmn2:sequenceFlow id="Flow_Published_To_EndJoin" sourceRef="Task_SetPublished" targetRef="Gateway_EndJoin" />
    <bpmn2:sequenceFlow id="Flow_PublishedWithWarning_To_EndJoin" sourceRef="Task_SetPublishedWithWarning" targetRef="Gateway_EndJoin" />
    <bpmn2:sequenceFlow id="Flow_Rejected_To_EndJoin" sourceRef="Task_SetRejected" targetRef="Gateway_EndJoin" />
    <bpmn2:sequenceFlow id="Flow_ManualReview_To_EndJoin" sourceRef="Task_SetManualReview" targetRef="Gateway_EndJoin" />
    <bpmn2:sequenceFlow id="Flow_EndJoin_To_End" sourceRef="Gateway_EndJoin" targetRef="EndEvent_ModerationCompleted" />
  </bpmn2:process>
