<?xml version="1.0" encoding="UTF-8" ?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:drools="http://www.jboss.org/drools" id="pre-publication-moderation-definitions" targetNamespace="https://dentamind.local/bpmn/content-moderation">
  <bpmn2:itemDefinition id="ItemDefinition_String" structureRef="java.lang.String" />
  <bpmn2:itemDefinition id="ItemDefinition_Number" structureRef="java.lang.Double" />
  <bpmn2:itemDefinition id="ItemDefinition_Boolean" structureRef="java.lang.Boolean" />
  <bpmn2:process id="pre_publication_moderation_process" drools:packageName="com.dentamind.moderation" drools:version="1.0" name="Pre-Publication Moderation Process" isExecutable="true" processType="Public">
    <bpmn2:property id="content_id" name="content_id" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="evidence_id" name="evidence_id" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="detected_domain" name="detected_domain" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="domain_confidence" name="domain_confidence" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="analysis_profile" name="analysis_profile" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="content_prompt_profile" name="content_prompt_profile" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="image_prompt_profile" name="image_prompt_profile" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="requires_domain_review" name="requires_domain_review" itemSubjectRef="ItemDefinition_Boolean" />
    <bpmn2:property id="has_image" name="has_image" itemSubjectRef="ItemDefinition_Boolean" />
    <bpmn2:property id="domain_dmn" name="domain_dmn" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="dmn_decision" name="dmn_decision" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="moderation_status" name="moderation_status" itemSubjectRef="ItemDefinition_String" />
    <bpmn2:property id="toxicity_score" name="toxicity_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="spam_score" name="spam_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="scam_score" name="scam_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="threat_score" name="threat_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="hate_score" name="hate_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="medical_claim_score" name="medical_claim_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="financial_risk_score" name="financial_risk_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="image_risk_score" name="image_risk_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="academic_integrity_score" name="academic_integrity_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="credential_fraud_score" name="credential_fraud_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="phishing_score" name="phishing_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="counterfeit_score" name="counterfeit_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="off_platform_payment_score" name="off_platform_payment_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="fake_listing_score" name="fake_listing_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="unrealistic_return_score" name="unrealistic_return_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="deposit_risk_score" name="deposit_risk_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="discrimination_score" name="discrimination_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="unsafe_medical_advice_score" name="unsafe_medical_advice_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="emergency_risk_score" name="emergency_risk_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="confidential_data_score" name="confidential_data_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="insider_threat_score" name="insider_threat_score" itemSubjectRef="ItemDefinition_Number" />
    <bpmn2:property id="is_repeat_offender" name="is_repeat_offender" itemSubjectRef="ItemDefinition_Boolean" />
    <bpmn2:startEvent id="StartEvent_ContentSubmitted" name="Content submitted">
      <bpmn2:outgoing>Flow_Start_To_SetPending</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:endEvent id="EndEvent_ModerationCompleted" name="Moderation completed">
      <bpmn2:incoming>Flow_EndJoin_To_End</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:exclusiveGateway id="Gateway_DomainConfidence" name="Domain profile usable?" gatewayDirection="Diverging" default="Flow_DomainConfidence_To_DomainRouting">
      <bpmn2:incoming>Flow_SetPending_To_DomainConfidence</bpmn2:incoming>
      <bpmn2:outgoing>Flow_DomainConfidence_To_ManualReview</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DomainConfidence_To_DomainRouting</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="Gateway_DomainRouting" name="Route to domain DMN" gatewayDirection="Diverging" default="Flow_DomainRouting_To_ManualReview">
      <bpmn2:incoming>Flow_DomainConfidence_To_DomainRouting</bpmn2:incoming>
      <bpmn2:outgoing>Flow_DomainRouting_To_EdTechName</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DomainRouting_To_EcommerceName</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DomainRouting_To_RealEstateName</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DomainRouting_To_HealthcareName</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DomainRouting_To_EnterpriseHrName</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DomainRouting_To_ManualReview</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="Gateway_DmnJoin" name="Domain DMN completed" gatewayDirection="Converging">
      <bpmn2:incoming>Flow_InvokeEdTech_To_DmnJoin</bpmn2:incoming>
      <bpmn2:incoming>Flow_InvokeEcommerce_To_DmnJoin</bpmn2:incoming>
      <bpmn2:incoming>Flow_InvokeRealEstate_To_DmnJoin</bpmn2:incoming>
      <bpmn2:incoming>Flow_InvokeHealthcare_To_DmnJoin</bpmn2:incoming>
      <bpmn2:incoming>Flow_InvokeEnterpriseHr_To_DmnJoin</bpmn2:incoming>
      <bpmn2:outgoing>Flow_DmnJoin_To_DecisionGateway</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="Gateway_ModerationDecision" name="Route by DMN decision" gatewayDirection="Diverging" default="Flow_DecisionGateway_To_ManualReview">
      <bpmn2:incoming>Flow_DmnJoin_To_DecisionGateway</bpmn2:incoming>
      <bpmn2:outgoing>Flow_DecisionGateway_To_Published</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DecisionGateway_To_PublishedWithWarning</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DecisionGateway_To_Rejected</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_DecisionGateway_To_ManualReview</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="Gateway_ManualReviewJoin" name="Manual review required" gatewayDirection="Converging">
      <bpmn2:incoming>Flow_DomainConfidence_To_ManualReview</bpmn2:incoming>
      <bpmn2:incoming>Flow_DomainRouting_To_ManualReview</bpmn2:incoming>
      <bpmn2:incoming>Flow_DecisionGateway_To_ManualReview</bpmn2:incoming>
      <bpmn2:outgoing>Flow_ManualReviewJoin_To_SetManualReview</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="Gateway_EndJoin" name="Final status joined" gatewayDirection="Converging">
      <bpmn2:incoming>Flow_Published_To_EndJoin</bpmn2:incoming>
      <bpmn2:incoming>Flow_PublishedWithWarning_To_EndJoin</bpmn2:incoming>
      <bpmn2:incoming>Flow_Rejected_To_EndJoin</bpmn2:incoming>
      <bpmn2:incoming>Flow_ManualReview_To_EndJoin</bpmn2:incoming>
      <bpmn2:outgoing>Flow_EndJoin_To_End</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:scriptTask id="Task_SetPendingModeration" name="Set status: PENDING_MODERATION" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_Start_To_SetPending</bpmn2:incoming>
      <bpmn2:outgoing>Flow_SetPending_To_DomainConfidence</bpmn2:outgoing>
      <bpmn2:script>
kcontext.setVariable(&quot;moderation_status&quot;, &quot;PENDING_MODERATION&quot;);
kcontext.setVariable(&quot;dmn_decision&quot;, null);
if (kcontext.getVariable(&quot;is_repeat_offender&quot;) == null) {
  kcontext.setVariable(&quot;is_repeat_offender&quot;, false);
}
      </bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetEdTechDmnName" name="Select EdTech DMN" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DomainRouting_To_EdTechName</bpmn2:incoming>
      <bpmn2:outgoing>Flow_EdTechName_To_InvokeEdTech</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;domain_dmn&quot;, &quot;EdTechModerationDecision&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetEcommerceDmnName" name="Select Ecommerce DMN" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DomainRouting_To_EcommerceName</bpmn2:incoming>
      <bpmn2:outgoing>Flow_EcommerceName_To_InvokeEcommerce</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;domain_dmn&quot;, &quot;EcommerceModerationDecision&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetRealEstateDmnName" name="Select Real Estate DMN" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DomainRouting_To_RealEstateName</bpmn2:incoming>
      <bpmn2:outgoing>Flow_RealEstateName_To_InvokeRealEstate</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;domain_dmn&quot;, &quot;RealEstateModerationDecision&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetHealthcareDmnName" name="Select Healthcare DMN" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DomainRouting_To_HealthcareName</bpmn2:incoming>
      <bpmn2:outgoing>Flow_HealthcareName_To_InvokeHealthcare</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;domain_dmn&quot;, &quot;HealthcareModerationDecision&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetEnterpriseHrDmnName" name="Select Enterprise HR DMN" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DomainRouting_To_EnterpriseHrName</bpmn2:incoming>
      <bpmn2:outgoing>Flow_EnterpriseHrName_To_InvokeEnterpriseHr</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;domain_dmn&quot;, &quot;EnterpriseHrModerationDecision&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetPublished" name="Set status: PUBLISHED" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DecisionGateway_To_Published</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Published_To_EndJoin</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;moderation_status&quot;, &quot;PUBLISHED&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetPublishedWithWarning" name="Set status: PUBLISHED_WITH_WARNING" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DecisionGateway_To_PublishedWithWarning</bpmn2:incoming>
      <bpmn2:outgoing>Flow_PublishedWithWarning_To_EndJoin</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;moderation_status&quot;, &quot;PUBLISHED_WITH_WARNING&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetRejected" name="Set status: REJECTED" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_DecisionGateway_To_Rejected</bpmn2:incoming>
      <bpmn2:outgoing>Flow_Rejected_To_EndJoin</bpmn2:outgoing>
      <bpmn2:script>kcontext.setVariable(&quot;moderation_status&quot;, &quot;REJECTED&quot;);</bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:scriptTask id="Task_SetManualReview" name="Set status: PENDING_HUMAN_REVIEW" scriptFormat="http://www.java.com/java">
      <bpmn2:incoming>Flow_ManualReviewJoin_To_SetManualReview</bpmn2:incoming>
      <bpmn2:outgoing>Flow_ManualReview_To_EndJoin</bpmn2:outgoing>
      <bpmn2:script>
kcontext.setVariable(&quot;moderation_status&quot;, &quot;PENDING_HUMAN_REVIEW&quot;);
if (kcontext.getVariable(&quot;dmn_decision&quot;) == null) {
  kcontext.setVariable(&quot;dmn_decision&quot;, &quot;MANUAL_REVIEW&quot;);
}
if (kcontext.getVariable(&quot;domain_dmn&quot;) == null) {
  kcontext.setVariable(&quot;domain_dmn&quot;, &quot;NONE&quot;);
}
      </bpmn2:script>
    </bpmn2:scriptTask>
    <bpmn2:businessRuleTask id="Task_InvokeEdTechDmn" name="Invoke EdTechModerationDecision.dmn" implementation="http://www.jboss.org/drools/dmn">
      <bpmn2:incoming>Flow_EdTechName_To_InvokeEdTech</bpmn2:incoming>
      <bpmn2:outgoing>Flow_InvokeEdTech_To_DmnJoin</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_namespaceInput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="namespace" />
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_modelInput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="model" />
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_decisionInput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="decision" />
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_academic_integrity_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="academic_integrity_score" />
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_credential_fraud_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="credential_fraud_score" />
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_spam_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="spam_score" />
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_toxicity_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="toxicity_score" />
        <bpmn2:dataInput id="Task_InvokeEdTechDmn_is_repeat_offenderInput" drools:dtype="java.lang.Boolean" itemSubjectRef="ItemDefinition_Boolean" name="is_repeat_offender" />
        <bpmn2:dataOutput id="Task_InvokeEdTechDmn_decisionOutput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="EdTechModerationDecision" />
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_namespaceInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_modelInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_decisionInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_academic_integrity_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_credential_fraud_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_spam_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_toxicity_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEdTechDmn_is_repeat_offenderInput</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>Task_InvokeEdTechDmn_decisionOutput</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_namespaceInput</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">https://dentamind.local/dmn/edtech-moderation</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">Task_InvokeEdTechDmn_namespaceInput</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_modelInput</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">EdTechModerationDecision</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">Task_InvokeEdTechDmn_modelInput</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_decisionInput</bpmn2:targetRef>
        <bpmn2:assignment>
          <bpmn2:from xsi:type="bpmn2:tFormalExpression">EdTechModerationDecision</bpmn2:from>
          <bpmn2:to xsi:type="bpmn2:tFormalExpression">Task_InvokeEdTechDmn_decisionInput</bpmn2:to>
        </bpmn2:assignment>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>academic_integrity_score</bpmn2:sourceRef>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_academic_integrity_scoreInput</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>credential_fraud_score</bpmn2:sourceRef>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_credential_fraud_scoreInput</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>spam_score</bpmn2:sourceRef>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_spam_scoreInput</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>toxicity_score</bpmn2:sourceRef>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_toxicity_scoreInput</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataInputAssociation>
        <bpmn2:sourceRef>is_repeat_offender</bpmn2:sourceRef>
        <bpmn2:targetRef>Task_InvokeEdTechDmn_is_repeat_offenderInput</bpmn2:targetRef>
      </bpmn2:dataInputAssociation>
      <bpmn2:dataOutputAssociation>
        <bpmn2:sourceRef>Task_InvokeEdTechDmn_decisionOutput</bpmn2:sourceRef>
        <bpmn2:targetRef>dmn_decision</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:businessRuleTask>
    <bpmn2:businessRuleTask id="Task_InvokeEcommerceDmn" name="Invoke EcommerceModerationDecision.dmn" implementation="http://www.jboss.org/drools/dmn">
      <bpmn2:incoming>Flow_EcommerceName_To_InvokeEcommerce</bpmn2:incoming>
      <bpmn2:outgoing>Flow_InvokeEcommerce_To_DmnJoin</bpmn2:outgoing>
      <bpmn2:ioSpecification>
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_namespaceInput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="namespace" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_modelInput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="model" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_decisionInput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="decision" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_phishing_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="phishing_score" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_counterfeit_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="counterfeit_score" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_off_platform_payment_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="off_platform_payment_score" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_scam_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="scam_score" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_image_risk_scoreInput" drools:dtype="java.lang.Double" itemSubjectRef="ItemDefinition_Number" name="image_risk_score" />
        <bpmn2:dataInput id="Task_InvokeEcommerceDmn_is_repeat_offenderInput" drools:dtype="java.lang.Boolean" itemSubjectRef="ItemDefinition_Boolean" name="is_repeat_offender" />
        <bpmn2:dataOutput id="Task_InvokeEcommerceDmn_decisionOutput" drools:dtype="java.lang.String" itemSubjectRef="ItemDefinition_String" name="EcommerceModerationDecision" />
        <bpmn2:inputSet>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_namespaceInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_modelInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_decisionInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_phishing_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_counterfeit_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_off_platform_payment_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_scam_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_image_risk_scoreInput</bpmn2:dataInputRefs>
          <bpmn2:dataInputRefs>Task_InvokeEcommerceDmn_is_repeat_offenderInput</bpmn2:dataInputRefs>
        </bpmn2:inputSet>
        <bpmn2:outputSet>
          <bpmn2:dataOutputRefs>Task_InvokeEcommerceDmn_decisionOutput</bpmn2:dataOutputRefs>
        </bpmn2:outputSet>
      </bpmn2:ioSpecification>
      <bpmn2:dataInputAssociation>
        <bpmn2:targetRef>Task_InvokeEcommerceDmn_namespaceInput</bpmn2:targetRef>
